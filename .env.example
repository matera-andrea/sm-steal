# Database Configuration (Prisma)
# Example PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/sm_steal_db?schema=public"

# Authentication (Clerk)
# Get these from your Clerk dashboard: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder_key"
CLERK_SECRET_KEY="sk_test_placeholder_key"

# Cloudflare R2 Storage (S3 Compatible)
# Get these from your Cloudflare dashboard
R2_ACCOUNT_ID="your_cloudflare_account_id_here"
R2_ACCESS_KEY_ID="your_r2_access_key_id_here"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"
R2_BUCKET_NAME="sm-steal-media-bucket"
R2_PUBLIC_URL="https://pub-placeholder.r2.dev"

# Rate Limiting (Upstash Redis)
# Get these from your Upstash console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://knowing-marten-12345.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_here"

# Admin Access Configuration
# Comma-separated or distinct Clerk User IDs that are allowed to access the admin dashboard and mutating APIs
ADMIN_ID="user_2placeholderadminid123"
DEV_ID="user_2placeholderdevid456"
